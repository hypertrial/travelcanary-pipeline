# TravelCanary v0.5.0 local environment.
# Copy to `.env` for local overrides.

DUCKDB_NAME=travelcanary.duckdb
# DUCKDB_PATH takes precedence over DUCKDB_NAME.
# DUCKDB_PATH=/absolute/path/to/travelcanary.duckdb
# DBT_PROFILES_DIR=/absolute/path/to/dbt/profiles
# Optional DuckDB session memory ceiling (e.g. 8GB). Blank uses DuckDB default.
DUCKDB_MEMORY_LIMIT=
EXPORT_DIR=exports

HTTP_CONNECT_TIMEOUT_SECONDS=10
HTTP_READ_TIMEOUT_SECONDS=30

# GDELT rolling window (days) for Events retention.
GDELT_ROLLING_WINDOW_DAYS=120

# Daily schedules are opt-in for local dev and CI.
TRAVELCANARY_DAILY_SCHEDULE_ENABLED=false

# UK FCDO: discover all countries from GOV.UK index API (226+). Set false to use seed CSV only.
UK_FCDO_DISCOVER_ALL_COUNTRIES=true
